<h2>Edit Order</h2>

<% if (error) { %>
  <p class="error"><%= error %></p>
<% } %>

<form action="/orders/<%= order.id %>?_method=PUT" method="POST">
  <label>Customer Name:</label>
  <input type="text" name="customerName" value="<%= order.customerName %>" required>

  <label>Coffee Type:</label>
  <select name="coffeeType" required>
    <option value="Espresso" <%= order.coffeeType === 'Espresso' ? 'selected' : '' %>>Espresso</option>
    <option value="Latte" <%= order.coffeeType === 'Latte' ? 'selected' : '' %>>Latte</option>
    <option value="Cappuccino" <%= order.coffeeType === 'Cappuccino' ? 'selected' : '' %>>Cappuccino</option>
    <option value="Americano" <%= order.coffeeType === 'Americano' ? 'selected' : '' %>>Americano</option>
    <option value="Mocha" <%= order.coffeeType === 'Mocha' ? 'selected' : '' %>>Mocha</option>
  </select>

  <label>Size:</label>
  <select name="size" required>
    <option value="Small" <%= order.size === 'Small' ? 'selected' : '' %>>Small</option>
    <option value="Medium" <%= order.size === 'Medium' ? 'selected' : '' %>>Medium</option>
    <option value="Large" <%= order.size === 'Large' ? 'selected' : '' %>>Large</option>
  </select>

  <label>Quantity:</label>
  <input type="number" name="quantity" value="<%= order.quantity %>" min="1" max="20" required>

  <button type="submit">Update Order</button>
</form>